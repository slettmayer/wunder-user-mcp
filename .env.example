# Required: long-lived refresh token for the end user the server acts on behalf of.
# The server exchanges this for short-lived access tokens automatically.
WUNDER_REFRESH_TOKEN=

# Required: tenant short-code used in the API URL path (e.g. carv6522).
WUNDER_TENANT=

# Optional: API base URL. Defaults to the production gateway.
# WUNDER_BASE_URL=https://go.api.gourban.services/v1

# Optional: default branch id applied to vehicle/rental calls when not passed per-tool.
# WUNDER_BRANCH_ID=

# Optional: default search radius (miles) for get_vehicles when a location is given
# without an explicit radius. The API requires lat+lng+rad together. Defaults to 5.
# WUNDER_DEFAULT_RADIUS_MI=5

# Optional: per-request timeout in seconds. Defaults to 30.
# WUNDER_HTTP_TIMEOUT=30
